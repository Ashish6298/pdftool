{
  "name": "invoice-pdf-annotation-and-fill",
  "version": "1.0.0",
  "description": "Invoice PDF Annotation and Fill Web Application",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "install:all": "npm install && npm install --workspace=backend && npm install --workspace=frontend",
    "prisma:generate": "npm run prisma:generate --workspace=backend",
    "prisma:migrate": "npm run prisma:migrate --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
